# ============================================================
# StarDash Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# From: Supabase Dashboard → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only — never expose to client

# ------------------------------------------------------------
# AI (optional — users can supply their own key in Settings)
# OpenRouter gives access to Gemini, GPT-4o, Claude, and more
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...

# ------------------------------------------------------------
# Cron security (required for star snapshot job)
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
CRON_SECRET=

# ------------------------------------------------------------
# Sentry — error tracking (optional)
# From: sentry.io → Project → Settings → Client Keys
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ------------------------------------------------------------
# Langfuse — AI observability (optional)
# From: cloud.langfuse.com → Project → Settings → API Keys
# NOTE: Always pass LANGFUSE_BASE_URL explicitly when creating
# Langfuse clients — the SDK defaults to LANGFUSE_BASEURL (no underscore)
# ------------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
