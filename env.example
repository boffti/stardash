# ==============================================================================
# StarDash — Environment Variables
# Copy this file to .env.local and fill in the values.
# ==============================================================================

# --- Supabase (required) ------------------------------------------------------
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Server-only — never expose to the client

# --- AI / OpenRouter (optional) -----------------------------------------------
# Get a key at https://openrouter.ai — required for AI categorization features.
# If omitted, users can supply their own key via the Settings page.
OPENROUTER_API_KEY=

# --- Cron secret (required) ---------------------------------------------------
# Shared secret used to authenticate calls to /api/cron/* routes.
# Use any long random string: openssl rand -hex 32
CRON_SECRET=

# --- Sentry (optional) --------------------------------------------------------
# Error monitoring — leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Langfuse (optional) ------------------------------------------------------
# LLM observability — leave blank to disable.
# Self-host at https://github.com/langfuse/langfuse or use Langfuse Cloud.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=                # e.g. https://cloud.langfuse.com
